{
  "name": "ae-ai-chat",
  "private": true,
  "version": "0.1.2",
  "author": "Randy Counsman <randycounsman@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/boo13/ae-ai-chat.git"
  },
  "homepage": "https://github.com/boo13/ae-ai-chat#readme",
  "bugs": {
    "url": "https://github.com/boo13/ae-ai-chat/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/rimraf/bin.js dist/* && node ./node_modules/typescript/bin/tsc -p \"tsconfig-build.json\" && node ./node_modules/vite/bin/vite.js build --watch false",
    "typecheck": "svelte-check --tsconfig tsconfig-build.json && tsc -p tsconfig-build.json --noEmit",
    "zxp": "node ./node_modules/rimraf/bin.js dist/* && node ./node_modules/typescript/bin/tsc -p \"tsconfig-build.json\" && cross-env ZXP_PACKAGE=true node ./node_modules/vite/bin/vite.js build --watch false",
    "debug": "cross-env SERVE_PANEL=true node ./node_modules/vite/bin/vite.js preview",
    "package": "node ./node_modules/rimraf/bin.js dist/* && node ./node_modules/typescript/bin/tsc -p \"tsconfig-build.json\" && cross-env ZXP_PACKAGE=true node ./node_modules/vite/bin/vite.js build --watch false",
    "symlink": "cross-env BOLT_ACTION=symlink node ./node_modules/vite/bin/vite.js",
    "few-shot:check": "node scripts/check-few-shot-examples.mjs",
    "errors:summarize": "node scripts/error-log-summary.mjs",
    "examples:export": "node scripts/export-example-scripts.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "dompurify": "^3.3.3",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.19.0",
    "@babel/plugin-proposal-class-properties": "^7.16.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.16.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.16.4",
    "@babel/preset-env": "^7.19.0",
    "@babel/preset-typescript": "^7.16.0",
    "@babel/runtime": "^7.16.3",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-image": "^3.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@rollup/plugin-replace": "^6.0.2",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/fs-extra": "^9.0.13",
    "@types/node": "^16.11.7",
    "@types/trusted-types": "^2.0.2",
    "babel-plugin-transform-scss": "^1.2.0",
    "babel-preset-env": "^1.7.0",
    "core-js": "3",
    "cross-env": "^7.0.3",
    "fs-extra": "^10.0.0",
    "rimraf": "^3.0.2",
    "rollup": "^4.42.0",
    "rollup-plugin-multi-input": "^1.5.0",
    "rollup-plugin-node-copy": "^1.0.4",
    "rollup-plugin-scss": "^4.0.1",
    "sass": "^1.89.1",
    "source-map": "^0.7.4",
    "svelte": "^5.33.14",
    "svelte-check": "^4.2.1",
    "svelte-preprocess": "^6.0.3",
    "types-for-adobe": "^7.2.3",
    "types-for-adobe-extras": "^0.0.9",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-cep-plugin": "^2.2.0"
  }
}
